# Ollama server (must be running: https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434

# Model used to embed PDF chunks and questions (pull first: `ollama pull nomic-embed-text`)
EMBED_MODEL=nomic-embed-text

# Model used to generate answers (pull first: `ollama pull qwen2.5:3b`)
GEN_MODEL=qwen2.5:3b

# Local ChromaDB storage directory
CHROMA_DIR=chroma_db

# Where uploaded PDFs are saved
UPLOAD_DIR=data/uploads
